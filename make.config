# Stack configurations
ASYNCIFY_DEFAULT_STACK_SIZE?=2097152
STACK_POOL_SIZE?=0
WASMFX_CONT_TABLE_INITIAL_CAPACITY?=1024
WASMFX_PRESERVE_SHADOW_STACK?=1
# Only relevant if WASMFX_PRESERVE_SHADOW_STACK is 1
WASMFX_CONT_SHADOW_STACK_SIZE?=65536

# Root
ROOT?=/opt/wasmfx

# Binaryen passes
BINARYEN?=$(ROOT)/binaryen
BINARYEN_FLAGS=--enable-nontrapping-float-to-int --enable-exception-handling --enable-reference-types --enable-multivalue --enable-bulk-memory --enable-gc --enable-stack-switching
WASM_OPT=$(BINARYEN)/bin/wasm-opt
WASM_OPT_FLAGS=$(BINARYEN_FLAGS) -O2 -g
ASYNCIFY=$(BINARYEN)/bin/wasm-opt
ASYNCIFY_FLAGS=$(WASM_OPT_FLAGS) --asyncify
WASM_MERGE=$(BINARYEN)/bin/wasm-merge 
WASM_MERGE_FLAGS=$(BINARYEN_FLAGS) --enable-multimemory

# Wasi
# A crude way to select whatever version of wasi-sdk is there at $ROOT.
WASI_SDK?=$(shell ls -d $(ROOT)/wasi-sdk-*-linux)
WASICC=$(WASI_SDK)/bin/clang
WASI_FLAGS=--sysroot=$(WASI_SDK)/share/wasi-sysroot -std=c17 -Wall -Wextra -Werror -Wpedantic -Wno-strict-prototypes -O3 -I inc

# Reference interpreter
WASM_INTERP?=$(ROOT)/stack-switching/interpreter/wasm

# Our fork of wasmtime
WASMTIME?=$(ROOT)/wasmfxtime/target/release/wasmtime

# Switch-specific dependencies (up-to-date wasmtime)
WASMTIME_SWITCH?=$(ROOT)/wasmtime/target/release/wasmtime
